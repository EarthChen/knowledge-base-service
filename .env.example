# Knowledge Base Service Configuration

# Server
HOST=0.0.0.0
PORT=8100
LOG_LEVEL=INFO

# FalkorDB
FALKORDB__HOST=falkordb
FALKORDB__PORT=6379
FALKORDB_PASSWORD=

# FalkorDB external port (docker-compose only)
FALKORDB_PORT=6379

# Embedding model (CodeRankEmbed: code retrieval SOTA, 137M params, 8192 context, 768 dim)
# backend: "onnx" (lightweight, ~50MB) or "torch" (full PyTorch, ~1.5GB)
EMBEDDING__MODEL_NAME=nomic-ai/CodeRankEmbed
EMBEDDING__DEVICE=auto
EMBEDDING__BACKEND=onnx
EMBEDDING__ONNX_PATH=
EMBEDDING__BATCH_SIZE=32
EMBEDDING__CHUNK_SIZE=64
EMBEDDING__USE_FP16=true
EMBEDDING__MAX_LENGTH=8192
EMBEDDING__QUERY_PREFIX=Represent this query for searching relevant code: 

# API Authentication (optional, leave empty to disable)
API_TOKEN=
